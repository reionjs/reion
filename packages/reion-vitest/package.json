{
  "name": "@reionjs/vitest",
  "version": "0.0.1",
  "description": "Vitest helpers for Reion: auto boot from reion.config, HTTP request client",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./setup": {
      "types": "./dist/setup.d.ts",
      "default": "./dist/setup.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "reion": ">=0.0.3",
    "vitest": ">=1.0.0"
  },
  "devDependencies": {
    "reion": "^0.0.3",
    "typescript": "^5.9.0",
    "vitest": "^3.2.4"
  }
}
